    {
        "id": "d9af3a3964995edb",
        "type": "function",
        "z": "1118086bb715c586",
        "name": "Func. Acionar Bomba",
        "func": "var nivel = msg.payload;\n\n// Recupera estado anterior da bomba (para evitar ficar ligando/desligando toda hora)\nvar estado = flow.get(\"bomba\") || \"OFF\";\n\nif (nivel < 20 && estado !== \"ON\") {\n    estado = \"ON\";\n}\nelse if (nivel > 80 && estado !== \"OFF\") {\n    estado = \"OFF\";\n}\n\n// Salva estado\nflow.set(\"bomba\", estado);\n\n// Envia comando\nmsg.payload = estado;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 240,
        "y": 400,
        "wires": [
            [
                "bb8bebc344bee65f"
            ]
        ]
