    {
        "id": "eb932d28aa54664d",
        "type": "function",
        "z": "1118086bb715c586",
        "name": "Status Nivel",
        "func": "var nivel = msg.payload;\n\nif(nivel < 20){\n     msg.payload = {nivel:nivel,status:\"CRITICO\",alert:1};\n}\n\nelse if(nivel < 80){\n     msg.payload = {nivel:nivel,status:\"BOM\",alert:0};\n}\n\nelse\n{ msg.payload = {nivel:nivel,status:\"CHEIO\",alert:0};\n}\n\n return msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 330,
        "y": 200,
        "wires": [
