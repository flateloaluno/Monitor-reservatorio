        "type": "function",
        "z": "1118086bb715c586",
        "name": "Insert MySQL",
        "func": "var n = msg.payload.nivel;\nvar s = msg.payload.status;\nmsg.topic = \"INSERT INTO sensores (nivel,status) VALUES (\" \n+ msg.payload.nivel + \",'\" + msg.payload.status + \"')\";\nreturn msg;",
        "outputs": 1,
